{
  "title": "Sovereign 7G Network",
  "uid": "s7g-main",
  "panels": [
    {
      "title": "Active Calls",
      "targets": [
        {
          "expr": "s7g_active_calls",
          "legendFormat": "Active Calls"
        }
      ]
    },
    {
      "title": "Call Quality (MOS)",
      "targets": [
        {
          "expr": "s7g_avg_mos",
          "legendFormat": "MOS"
        }
      ]
    },
    {
      "title": "Nodes Online",
      "targets": [
        {
          "expr": "s7g_online_nodes",
          "legendFormat": "Online Nodes"
        }
      ]
    },
    {
      "title": "Slash Rate",
      "targets": [
        {
          "expr": "rate(s7g_slash_rate[1h])",
          "legendFormat": "Slashes/hr"
        }
      ]
    },
    {
      "title": "Revenue (S7G)",
      "targets": [
        {
          "expr": "s7g_total_revenue",
          "legendFormat": "Total Revenue"
        }
      ]
    }
  ]
}
